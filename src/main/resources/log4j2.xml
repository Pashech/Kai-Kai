<Configuration status="debug" packages="biz.paluch.logging.gelf.log4j2">
    <Appenders>
        <Gelf name="gelf" host="udp:${env:GRAYLOG_HOST}" port="${env:GRAYLOG_PORT}" version="1.0"
              extractStackTrace="true"
              filterStackTrace="true" mdcProfiling="true" includeFullMdc="true" maximumMessageSize="8192"
              originHost="harvester" additionalFieldTypes="fieldName1=String,fieldName2=Double,fieldName3=Long"
              ignoreExceptions="true">
            <Field name="timestamp" pattern="%d{dd MMM yyyy HH:mm:ss,SSS}"/>
            <Field name="level" pattern="%level"/>
            <Field name="simpleClassName" pattern="%C{1}"/>
            <Field name="className" pattern="%C"/>
            <Field name="server" pattern="%host"/>
            <Field name="server.fqdn" pattern="%host{fqdn}"/>
            <Field name="fieldName2" literal="fieldValue2"/> <!-- This is a static field -->
            <Field name="mdcField2" mdc="mdcField2"/> <!-- This is a field using MDC -->
            <DynamicMdcFields regex="mdc.*"/>
            <DynamicMdcFields regex="(mdc|MDC)fields"/>
            <DynamicMdcFieldType regex="my_field.*" type="String"/>
        </Gelf>

        <File name="File" fileName="logs/harvester.log" ignoreExceptions="true">
            <!--            <PatternLayout pattern="%d{yyy-MM-dd} %d{HH:mm:ss} %-5level %logger{36} - %msg%n"/> -->
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5p %c{1}:%L - %m%n"/>
        </File>

        <Failover name="Failover" primary="gelf">
            <Failovers>
                <AppenderRef ref="File"/>
            </Failovers>
        </Failover>


    </Appenders>
    <Loggers>
        <Root level="INFO">
            <!--            <AppenderRef ref="Failover"/>-->
            <AppenderRef ref="File"/>
            <AppenderRef ref="gelf"/>
        </Root>
    </Loggers>
</Configuration>